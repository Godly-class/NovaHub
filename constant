-- ========== 通知堆疊系統 ==========
local ActiveNotifications = {}
local function ShowNotification(Message, Duration)
	Duration = Duration or 2.5

	local Notif = Instance.new("Frame")
	Notif.BackgroundColor3 = Color3.fromRGB(10, 10, 10)
	Notif.BorderColor3 = BORDER_COLOR
	Notif.ZIndex = 100
	Notif.ClipsDescendants = true

	local NotifText = Instance.new("TextLabel")
	NotifText.Parent = Notif
	NotifText.Position = UDim2.new(0, 4, 0, 0)
	NotifText.BackgroundTransparency = 1
	NotifText.FontFace = FONT
	NotifText.TextSize = 10
	NotifText.TextColor3 = TEXT_COLOR
	NotifText.TextXAlignment = Enum.TextXAlignment.Left
	NotifText.Text = Message
	NotifText.TextTruncate = Enum.TextTruncate.AtEnd
	NotifText.ZIndex = 101

	-- 自適應大小
	local textWidth = NotifText.TextBounds.X
	NotifText.Size = UDim2.new(0, textWidth, 0, 10)
	Notif.Size = UDim2.new(0, textWidth + 12, 0, 14)

	-- 加入堆疊
	table.insert(ActiveNotifications, Notif)
	Notif.Parent = PlayerGui:FindFirstChild("GameUI") or PlayerGui

	-- 計算所有通知位置
	local function RepositionAll()
		local totalY = 28
		for i, n in ipairs(ActiveNotifications) do
			if n and n.Parent then
				local targetPos = UDim2.new(0, 6, 0, totalY)
				n:TweenPosition(targetPos, "Out", "Quad", 0.2)
				totalY += n.AbsoluteSize.Y + 4
			end
		end
		local cleaned = {}
		for _, n in ipairs(ActiveNotifications) do
			if n and n.Parent then
				table.insert(cleaned, n)
			end
		end
		ActiveNotifications = cleaned
	end

	Notif.Position = UDim2.new(0, -210, 0, 28)
	RepositionAll()

	task.delay(Duration, function()
		if Notif and Notif.Parent then
			Notif:TweenPosition(UDim2.new(0, -210, 0, Notif.Position.Y.Offset), "In", "Quad", 0.2)
			task.delay(0.2, function()
				if Notif and Notif.Parent then
					Notif:Destroy()
				end
				RepositionAll()
			end)
		end
	end)
end

