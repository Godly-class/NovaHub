		-- ========== SLIDER ==========
		function Section:CreateSlider(SliderText, Min, Max, Default, Callback)
			Min = Min or 0
			Max = Max or 100
			Default = Default or 50

			local SliderContainer = Instance.new("Frame")
			SliderContainer.Parent = ContentHolder
			SliderContainer.Size = UDim2.new(1, 0, 0, 32)
			SliderContainer.BackgroundTransparency = 1

			local SliderLabel = Instance.new("TextLabel")
			SliderLabel.Parent = SliderContainer
			SliderLabel.Size = UDim2.new(1, 0, 0, 14)
			SliderLabel.BackgroundTransparency = 1
			SliderLabel.FontFace = FONT
			SliderLabel.TextSize = 9
			SliderLabel.TextColor3 = TEXT_COLOR
			SliderLabel.TextXAlignment = Enum.TextXAlignment.Left
			SliderLabel.Text = SliderText .. ": " .. Default

			local Track = Instance.new("Frame")
			Track.Parent = SliderContainer
			Track.Size = UDim2.new(1, 0, 0, 6)
			Track.Position = UDim2.new(0, 0, 0, 18)
			Track.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
			Track.BorderColor3 = BORDER_COLOR

			local Fill = Instance.new("Frame")
			Fill.Parent = Track
			Fill.Size = UDim2.new((Default - Min) / (Max - Min), 0, 1, 0)
			Fill.BackgroundColor3 = BORDER_COLOR
			Fill.BorderSizePixel = 0

			local Knob = Instance.new("Frame")
			Knob.Parent = Track
			Knob.Size = UDim2.new(0, 10, 0, 14)
			Knob.Position = UDim2.new((Default - Min) / (Max - Min), -5, 0.5, -7)
			Knob.BackgroundColor3 = TEXT_COLOR
			Knob.BorderSizePixel = 0

			local currentValue = Default
			local isDragging = false
			local dragConnection = nil

			local function SetValueFromPosition(input)
				local pos = (input.Position.X - Track.AbsolutePosition.X) / Track.AbsoluteSize.X
				pos = math.clamp(pos, 0, 1)
				currentValue = math.floor(Min + pos * (Max - Min))
				Fill.Size = UDim2.new(pos, 0, 1, 0)
				Knob.Position = UDim2.new(pos, -5, 0.5, -7)
				SliderLabel.Text = SliderText .. ": " .. currentValue
				if Callback then Callback(currentValue) end
			end

			local function StartDrag(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1
					or input.UserInputType == Enum.UserInputType.Touch then
					isDragging = true
					SetValueFromPosition(input)

					dragConnection = UserInputService.InputChanged:Connect(function(changed)
						if isDragging and (changed.UserInputType == Enum.UserInputType.MouseMovement
							or changed.UserInputType == Enum.UserInputType.Touch) then
							SetValueFromPosition(changed)
						end
					end)
				end
			end

			local function StopDrag(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1
					or input.UserInputType == Enum.UserInputType.Touch then
					isDragging = false
					if dragConnection then
						dragConnection:Disconnect()
						dragConnection = nil
					end
				end
			end

			Knob.InputBegan:Connect(StartDrag)
			Knob.InputEnded:Connect(StopDrag)

			Track.InputBegan:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1
					or input.UserInputType == Enum.UserInputType.Touch then
					SetValueFromPosition(input)
					StartDrag(input)
				end
			end)
			Track.InputEnded:Connect(StopDrag)

			UserInputService.InputEnded:Connect(function(input)
				if isDragging and (input.UserInputType == Enum.UserInputType.MouseButton1
					or input.UserInputType == Enum.UserInputType.Touch) then
					StopDrag(input)
				end
			end)

			table.insert(itemHeights, 32)
			UpdateCardHeight()

			return {
				Set = function(value)
					currentValue = math.clamp(value, Min, Max)
					local pos = (currentValue - Min) / (Max - Min)
					Fill.Size = UDim2.new(pos, 0, 1, 0)
					Knob.Position = UDim2.new(pos, -5, 0.5, -7)
					SliderLabel.Text = SliderText .. ": " .. currentValue
				end,
				Get = function()
					return currentValue
				end
			}
		end

