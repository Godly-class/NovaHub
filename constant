					Knob:TweenPosition(UDim2.new(0, 2, 0.5, -7), "Out", "Quad", 0.15)
				end
			end

			if Default then
				ToggleState = true
				task.defer(UpdateVisual)
			end

			ToggleContainer.MouseButton1Click:Connect(function()
				ToggleState = not ToggleState
				UpdateVisual()
				if Callback then Callback(ToggleState) end
			end)

			table.insert(itemHeights, 24)
			UpdateCardHeight()

			return {
				Set = function(value)
					ToggleState = value
					UpdateVisual()
				end,
				Get = function()
					return ToggleState
				end
			}
		end

