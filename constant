					UpdateCardHeight()
				else
					DropList.Size = UDim2.new(1, 0, 0, 0)
					DropContainer.Size = UDim2.new(1, 0, 0, 30)
					itemHeights[#itemHeights] = 30
					UpdateCardHeight()
				end
			end)

			table.insert(itemHeights, 30)
			UpdateCardHeight()
			return DropBtn
		end

		-- ========== COLOR PICKER ==========
		function Section:CreateColorPicker(PickerText, DefaultColor, Callback)
			DefaultColor = DefaultColor or Color3.fromRGB(255, 100, 149)

			local ColorH, ColorS, ColorV = DefaultColor:ToHSV()

			local PickerContainer = Instance.new("Frame")
			PickerContainer.Parent = ContentHolder
			PickerContainer.Size = UDim2.new(1, 0, 0, 36)
			PickerContainer.BackgroundTransparency = 1

			local PickerLabel = Instance.new("TextLabel")
			PickerLabel.Parent = PickerContainer
			PickerLabel.Size = UDim2.new(0, 80, 0, 14)
			PickerLabel.Position = UDim2.new(0, 0, 0, 0)
			PickerLabel.BackgroundTransparency = 1
			PickerLabel.FontFace = FONT
			PickerLabel.TextSize = 9
			PickerLabel.TextColor3 = TEXT_COLOR
			PickerLabel.TextXAlignment = Enum.TextXAlignment.Left
			PickerLabel.Text = PickerText

			local PreviewOuter = Instance.new("Frame")
			PreviewOuter.Parent = PickerContainer
			PreviewOuter.Size = UDim2.new(0, 34, 0, 18)
			PreviewOuter.Position = UDim2.new(1, -34, 0, -2)
			PreviewOuter.BackgroundColor3 = Color3.fromRGB(45, 45, 50)
			PreviewOuter.BorderSizePixel = 0

			local PreviewBox = Instance.new("TextButton")
			PreviewBox.Parent = PreviewOuter
			PreviewBox.Size = UDim2.new(1, -2, 1, -2)
			PreviewBox.Position = UDim2.new(0, 1, 0, 1)
			PreviewBox.BackgroundColor3 = DefaultColor
			PreviewBox.Text = ""
			PreviewBox.AutoButtonColor = false
			PreviewBox.BorderSizePixel = 0

			local HexLabel = Instance.new("TextLabel")
			HexLabel.Parent = PickerContainer
			HexLabel.Size = UDim2.new(1, -42, 0, 14)
			HexLabel.Position = UDim2.new(0, 0, 0, 16)
			HexLabel.BackgroundTransparency = 1
			HexLabel.FontFace = FONT
			HexLabel.TextSize = 8
			HexLabel.TextColor3 = BORDER_COLOR
			HexLabel.TextXAlignment = Enum.TextXAlignment.Left
			HexLabel.Text = string.format("#%02X%02X%02X",
				math.floor(DefaultColor.R * 255),
				math.floor(DefaultColor.G * 255),
				math.floor(DefaultColor.B * 255))

			local ColorWindow = Instance.new("Frame")
			ColorWindow.Parent = ScreenGui
			ColorWindow.Size = UDim2.new(0, 180, 0, 160)
			ColorWindow.BackgroundColor3 = Color3.fromRGB(20, 20, 23)
			ColorWindow.BorderSizePixel = 1
			ColorWindow.BorderColor3 = Color3.fromRGB(45, 45, 50)
			ColorWindow.Visible = false
			ColorWindow.ZIndex = 50

			local SatMap = Instance.new("ImageButton")
			SatMap.Parent = ColorWindow
			SatMap.Size = UDim2.new(0, 150, 0, 150)
			SatMap.Position = UDim2.new(0, 5, 0, 5)
			SatMap.Image = "rbxassetid://4155801252"
			SatMap.ScaleType = Enum.ScaleType.Slice
			SatMap.BorderSizePixel = 0
			SatMap.BackgroundColor3 = Color3.fromHSV(ColorH, 1, 1)
			SatMap.ZIndex = 50

			local HueMap = Instance.new("ImageButton")
			HueMap.Parent = ColorWindow
			HueMap.Size = UDim2.new(0, 15, 0, 150)
			HueMap.Position = UDim2.new(0, 160, 0, 5)
			HueMap.Image = "rbxassetid://4155801252"
			HueMap.BorderSizePixel = 0
			HueMap.ZIndex = 50

			local HueGradient = Instance.new("UIGradient")
			HueGradient.Parent = HueMap
			HueGradient.Rotation = -90
			HueGradient.Color = ColorSequence.new({
				ColorSequenceKeypoint.new(0, Color3.new(1, 0, 0)),
				ColorSequenceKeypoint.new(0.17, Color3.new(1, 1, 0)),
				ColorSequenceKeypoint.new(0.33, Color3.new(0, 1, 0)),
				ColorSequenceKeypoint.new(0.5, Color3.new(0, 1, 1)),
				ColorSequenceKeypoint.new(0.67, Color3.new(0, 0, 1)),
				ColorSequenceKeypoint.new(0.83, Color3.new(1, 0, 1)),
				ColorSequenceKeypoint.new(1, Color3.new(1, 0, 0))
			})

			local Pointer = Instance.new("Frame")
			Pointer.Parent = SatMap
			Pointer.Size = UDim2.new(0, 4, 0, 4)
			Pointer.BackgroundColor3 = Color3.new(1, 1, 1)
			Pointer.BorderColor3 = Color3.new(0, 0, 0)
			Pointer.BorderSizePixel = 1
			Pointer.ZIndex = 51
			Pointer.Position = UDim2.new(ColorS, 0, 1 - ColorV, 0)

			local HuePointer = Instance.new("Frame")
			HuePointer.Parent = HueMap
			HuePointer.Size = UDim2.new(1, 0, 0, 2)
			HuePointer.BackgroundColor3 = Color3.new(1, 1, 1)
			HuePointer.BorderColor3 = Color3.new(0, 0, 0)
			HuePointer.BorderSizePixel = 1
			HuePointer.ZIndex = 51
			HuePointer.Position = UDim2.new(0, 0, 1 - ColorH, 0)

			local function UpdateColor()
				local finalColor = Color3.fromHSV(ColorH, ColorS, ColorV)
				SatMap.BackgroundColor3 = Color3.fromHSV(ColorH, 1, 1)
				PreviewBox.BackgroundColor3 = finalColor
				Pointer.Position = UDim2.new(ColorS, 0, 1 - ColorV, 0)
				HuePointer.Position = UDim2.new(0, 0, 1 - ColorH, 0)
				HexLabel.Text = string.format("#%02X%02X%02X",
					math.floor(finalColor.R * 255),
					math.floor(finalColor.G * 255),
					math.floor(finalColor.B * 255))
				if Callback then Callback(finalColor) end
			end

			PreviewBox.MouseButton1Click:Connect(function()
				ColorWindow.Visible = not ColorWindow.Visible
				local posX = PreviewBox.AbsolutePosition.X - 175
				local posY = PreviewBox.AbsolutePosition.Y - 140
				ColorWindow.Position = UDim2.new(0, math.max(0, posX), 0, math.max(0, posY))
			end)

			SatMap.InputBegan:Connect(function(i)
				if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
					local con
					con = UserInputService.InputChanged:Connect(function(input)
						if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
							ColorS = math.clamp((input.Position.X - SatMap.AbsolutePosition.X) / SatMap.AbsoluteSize.X, 0, 1)
							ColorV = 1 - math.clamp((input.Position.Y - SatMap.AbsolutePosition.Y) / SatMap.AbsoluteSize.Y, 0, 1)
							UpdateColor()
						end
					end)
					UserInputService.InputEnded:Connect(function(input)
						if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
							con:Disconnect()
						end
					end)
				end
			end)

			HueMap.InputBegan:Connect(function(i)
				if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
					local con
					con = UserInputService.InputChanged:Connect(function(input)
						if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
							ColorH = 1 - math.clamp((input.Position.Y - HueMap.AbsolutePosition.Y) / HueMap.AbsoluteSize.Y, 0, 1)
							UpdateColor()
						end
					end)
					UserInputService.InputEnded:Connect(function(input)
						if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
							con:Disconnect()
						end
					end)
				end
			end)

			UpdateColor()

			table.insert(itemHeights, 36)
			UpdateCardHeight()

			return {
				Set = function(color)
					ColorH, ColorS, ColorV = color:ToHSV()
					UpdateColor()
				end,
				Get = function()
					return Color3.fromHSV(ColorH, ColorS, ColorV)
				end
			}
		end

		return Section
	end

	-- ========== TAB 點擊事件 ==========
	local TabOpen = false

	Button.MouseButton1Click:Connect(function()
		if TabOpen then
			Page.Visible = false
			MainFrame.Visible = false
			TabOpen = false

			for _, t in ipairs(Tabs) do
				t.Button.TextColor3 = TEXT_COLOR
			end
		else
			for _, child in ipairs(MainFrame:GetChildren()) do
				if child:IsA("Frame") then
					child.Visible = false
				end
			end

			for _, t in ipairs(Tabs) do
				t.Tab.TabOpen = false
				t.Button.TextColor3 = TEXT_COLOR
			end

			Page.Visible = true
			MainFrame.Visible = true
			TabOpen = true

			Button.TextColor3 = BORDER_COLOR

			task.wait()
			Indicator.Size = UDim2.new(0, Button.AbsoluteSize.X - 20, 0, 2)
			Indicator.Position = UDim2.new(0, Button.AbsolutePosition.X + 10, 0, 22)
		end
	end)

	Tab.TabOpen = TabOpen

	return Tab
end
